DATABASE_URL="postgresql://postgres:password@localhost:5432/stella?schema=public"

# JWT signing secret (set a strong random value in production)
JWT_SECRET="change-me"

# Access token TTL (supported formats: e.g. 900s, 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token TTL (in days)
JWT_REFRESH_DAYS="30"

# Optional: extra secret mixed into refresh-token hashing (keep private like JWT_SECRET)
REFRESH_TOKEN_PEPPER="change-me-too"

# CORS
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

